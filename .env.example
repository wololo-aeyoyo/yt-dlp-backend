CHIBISAFE_BASE_URL=https://chibisafe.wololoaeyoyo.com
CHIBISAFE_API_KEY=your_api_key_here
DOWNLOAD_DIR=/tmp/yt-dlp-downloads
MAX_FILESIZE_MB=2000

# Observability (all optional — omit to disable)
ENVIRONMENT=production
JSON_LOGS=true

# Loki — log aggregation
LOKI_URL=http://localhost:3100

# Tempo — distributed tracing via OTLP/HTTP
OTEL_ENDPOINT=http://localhost:4318

# Mimir — Prometheus metrics scraped from /metrics (true by default)
PROMETHEUS_ENABLED=true

# Pyroscope — continuous profiling
PYROSCOPE_URL=http://localhost:4040

# Postgres database connection settings
PG_HOST=localhost
PG_PORT=5432
PG_USER=user
PG_PASSWORD=password
PG_DATABASE=yt-dlp-db

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me
JWT_EXPIRE_HOURS=24

